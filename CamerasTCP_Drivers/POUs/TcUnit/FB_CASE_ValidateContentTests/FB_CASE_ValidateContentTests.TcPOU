    <Method Name="numberOfOuters01_ValueToLittlebErrorTrue" Id="{b44f659f-6262-4429-8424-4805520f7114}" FolderPath="03.NumberOfOuters\">
      <Declaration><![CDATA[METHOD INTERNAL numberOfOuters01_ValueToLittlebErrorTrue
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0301				: FB_CASE_ValidateContent;
	fTrig0301						: F_TRIG;
	nCycles0301						: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0301, stProductInstruction:= stProductInstruction_test_0301);

//Change some data for test scenario below
stCACData_test_0301.NumberOfOuters := 45;
	


TcUnit.TEST('numberOfOuters01_ValueToLittlebErrorTrue');

fbCaseTest0301(
	bExecute:= TRUE, 
	bIsDuplicateOuters:= FALSE, 
	bIsDuplicatePacks:= FALSE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0301, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
	stCaseRejectReasons:= stCaseRejectReasons_tests, 
	stCACData:= stCACData_test_0301, 
	bDone=> bDone, 
	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_test_0301, 
	nValidationIndex=> nValidationIndex
);

fTrig0301(CLK:= fbCaseTest0301.bBusy);
nCycles0301 := nCycles0301 + 1;	

IF fTrig0301.Q AND nCycles0301 <= 50 THEN	
	
	AssertEquals_BOOL(Expected := TRUE,
					  Actual := fbCaseTest0301.bError,
					  Message := 'Numbers of outer wrong value didnt call error'
	);
	
	AssertEquals_STRING(Expected := 'XXVAL045XX',
						Actual := TO_STRING(fbCaseTest0301.sRejectCode),
						Message := 'Wrong value of nErrorID'
	);
	
	AssertEquals_INT(Expected := 45,
					 Actual := stCACData_test_0301.NumberOfOuters,
					 Message := 'INT Values differ'
	);	
	
	TEST_FINISHED();
	
ELSIF nCycles0301 > 50 THEN
	
	AssertTrue(Condition := TRUE,
			   Message := 'Timeout CASE loop within FB_CASE_Validation'
	);	 

	
	TEST_FINISHED();
END_IF]]></ST>
      </Implementation>
    </Method>
