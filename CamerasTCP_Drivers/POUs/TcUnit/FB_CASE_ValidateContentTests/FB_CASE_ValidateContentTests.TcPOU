	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_tets, 
	nValidationIndex=> nValidationIndex
);
	
rTrig(CLK:= fbCaseTest0101.bDone);
nCycles := nCycles + 1;	

		
AssertEquals_BOOL(Expected 	:= FALSE,
				  Actual 	:= fbCaseTest0101.bError,
				  Message 	:= 'FB no executed wrong output'
);

AssertEquals_BOOL(Expected 	:= FALSE,
				  Actual 	:= fbCaseTest0101.bDone,
				  Message 	:= 'B no executed wrong output'
);

TEST_FINISHED();]]></ST>
      </Implementation>
