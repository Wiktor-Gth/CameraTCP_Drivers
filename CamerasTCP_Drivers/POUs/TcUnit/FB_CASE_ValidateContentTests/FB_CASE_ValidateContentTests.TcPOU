    <Method Name="dataConsistancy05_NumberOfOutersToSmall" Id="{baa97d41-ea49-4e2b-b29e-f927dec1b38f}" FolderPath="02.DataConsistancy\">
      <Declaration><![CDATA[METHOD INTERNAL dataConsistancy05_NumberOfOutersToSmall
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0205				: FB_CASE_ValidateContent;
	rTrig0205					: R_TRIG;
	nCycles0205					: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0205, stProductInstruction:= stProductInstruction_test_0205);

//Change some data for test scenario below
stCACData_test_0205.NumberOfOuters := 25;
	
TcUnit.TEST('dataConsistancy05_NumberOfOutersToSmall');


fbCaseTest0205(
	bExecute:= TRUE, 
	bIsDuplicateOuters:= FALSE, 
	bIsDuplicatePacks:= FALSE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0205, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
	stCaseRejectReasons:= stCaseRejectReasons_tests, 
	stCACData:= stCACData_test_0205, 
	bDone=> bDone, 
	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_test_0205, 
	nValidationIndex=> nValidationIndex
);
	
rTrig0205(CLK:= fbCaseTest0205.bDone);
nCycles0205 := nCycles0205 + 1;	

