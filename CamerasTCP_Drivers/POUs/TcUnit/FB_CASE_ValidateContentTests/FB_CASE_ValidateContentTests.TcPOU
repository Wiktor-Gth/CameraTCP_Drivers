<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_CASE_ValidateContentTests" Id="{822c9689-f495-489e-84c7-63cbf678b11e}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_CASE_ValidateContentTests EXTENDS TcUnit.FB_TestSuite

VAR
	
(* General data *)
	stCTDateTime_tests					: ST_SYSTEM_DateTime;	
	stProductInstruction_tests			: ST_PCM_Status;
	nSecquentionalCounter_tests			: UDINT;
	stCodeInfo_Outer_tests				: ST_CodeInfo;
	stCaseRejectReasons_tests			: ST_RejectReasonsForCase;
	stRejectReasonsForOuter_tests		: ST_RejectReasonsForOuter;
	stOuterDataNotFound_tests			: ST_RejectItems;

(* 01.Main tests container *)

	stProductInstruction_test_0101		: ST_PCM_Status;
	stCACData_test_0101 				: ST_CAC_Data;
	
	stCACData_tests 					: ST_CAC_Data;
	
(* 02.DataConsistancy tests container *)
	stProductInstruction_test_0201		: ST_PCM_Status;
	stCACData_test_0201 				: ST_CAC_Data;
	sRejectCode_test_0201				: T_MaxString;
	
	stProductInstruction_test_0202		: ST_PCM_Status;
	stCACData_test_0202 				: ST_CAC_Data;
	sRejectCode_test_0202				: T_MaxString;	
	
	
	stProductInstruction_test_0203		: ST_PCM_Status;
	stCACData_test_0203 				: ST_CAC_Data;
	sRejectCode_test_0203				: T_MaxString;
	
	stProductInstruction_test_0204		: ST_PCM_Status;
	stCACData_test_0204 				: ST_CAC_Data;
	sRejectCode_test_0204				: T_MaxString;

	
	stProductInstruction_test_0205		: ST_PCM_Status;
	stCACData_test_0205 				: ST_CAC_Data;
	sRejectCode_test_0205				: T_MaxString;
	
	stProductInstruction_test_0206		: ST_PCM_Status;
	stCACData_test_0206 				: ST_CAC_Data;
	sRejectCode_test_0206				: T_MaxString;

(* 03.NumberOfOuters tests container *)
	stProductInstruction_test_0301		: ST_PCM_Status;
	stCACData_test_0301 				: ST_CAC_Data;
	sRejectCode_test_0301				: T_MaxString;
	
	stProductInstruction_test_0302		: ST_PCM_Status;
	stCACData_test_0302 				: ST_CAC_Data;
	sRejectCode_test_0302				: T_MaxString;
	
	stProductInstruction_test_0303		: ST_PCM_Status;
	stCACData_test_0303 				: ST_CAC_Data;
	sRejectCode_test_0303				: T_MaxString;
	
(* 04.OuterAggrDissable tests container *)
	stProductInstruction_test_0401		: ST_PCM_Status;
	stCACData_test_0401 				: ST_CAC_Data;
	sRejectCode_test_0401				: T_MaxString;
	
	stProductInstruction_test_0402		: ST_PCM_Status;
	stCACData_test_0402 				: ST_CAC_Data;
	sRejectCode_test_0402				: T_MaxString;

(* 05.OuterAggrEnable tests container *)
	stProductInstruction_test_0501		: ST_PCM_Status;
	stCACData_test_0501 				: ST_CAC_Data;
	sRejectCode_test_0501				: T_MaxString;
	
	stProductInstruction_test_0502		: ST_PCM_Status;
	stCACData_test_0502 				: ST_CAC_Data;
	sRejectCode_test_0502				: T_MaxString;

(* 06.DuplicateHandler tests container *)
	
	stProductInstruction_test_0601		: ST_PCM_Status;
	stCACData_test_0601 				: ST_CAC_Data;
	sRejectCode_test_0601				: T_MaxString;
	
	stCACData_test_0602 				: ST_CAC_Data;
	stProductInstruction_test_0602		: ST_PCM_Status;
	sRejectCode_test_0602				: T_MaxString;
	
(* 07.OACmissing tests container *)
	
	stProductInstruction_test_0701		: ST_PCM_Status;
	stCACData_test_0701 				: ST_CAC_Data;
	sRejectCode_test_0701				: T_MaxString;
	
	stCACData_test_0702 				: ST_CAC_Data;
	stProductInstruction_test_0702		: ST_PCM_Status;
	sRejectCode_test_0702				: T_MaxString;
	
	sRejectCode_tets					: T_MaxString;
	
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
//==============================================================
//01.Main
//==============================================================
main01_bExecuteFalseNoAction();

//==============================================================
//02.DataConsistancy
//==============================================================
dataConsistancy01_NumOfOutersWrong();
dataConsistancy02_NumOfOutersExceedcMAX_Outers();
dataConsistancy03_ValidationCodeNotFoundInInfeedQueue();
dataConsistancy04_OuterCodeVal_IndexErrorFound();
dataConsistancy05_NumberOfOutersToSmall();
dataConsistancy06_NumberOfOutersToBig();

//==============================================================
//03.NumberOfOuters
//==============================================================
numberOfOuters01_ValueToLittlebErrorTrue();
numberOfOuters02_ValueGraterErrorTrue();
numberOfOuters03_ValueToLittlebErrorTrueRejectCodeWright();

//==============================================================
//04.OuterAggrDissable
//==============================================================
outerAggrDissable01_sRejectCodeOK();

//==============================================================
//05.OuterAggrEnable
//==============================================================
outerAggrEnable01_PacksPerOuterZero();
outerAggrEnable02_PacksPerCaseZero();


//==============================================================
//06.DuplicatesHandler
//==============================================================
duplicateHandler01_OuterDuplicatebErrorTrue();
duplicateHandler02_PackDuplicatebErrorTrue();

//==============================================================
//07.OACmissing
//==============================================================
oacMissing01nErrorID21();]]></ST>
    </Implementation>
    <Folder Name="01.Main" Id="{3efa2ee4-d7cd-44eb-a85a-a0e477b57b3b}" />
    <Folder Name="02.DataConsistancy" Id="{693924a5-42e2-4208-b929-e9e914d01e79}" />
    <Folder Name="03.NumberOfOuters" Id="{b0fe4446-7114-4527-b271-a6e33e4ed61f}" />
    <Folder Name="04.OuterAggrDissable" Id="{8114e77b-5754-4ae2-91e5-6dedce0f4fa5}" />
    <Folder Name="05.OuterAggrEnable" Id="{cbcc7ee9-3d0b-492a-abb0-b08e73444fc1}" />
    <Folder Name="06. DuplicatesHandler" Id="{2a79a149-c2ae-4192-80f2-d9269d1098d2}" />
    <Folder Name="07.OACmissing" Id="{c48d55b4-192e-4e54-9884-7295a025f741}" />
    <Method Name="dataConsistancy01_NumOfOutersWrong" Id="{5a7eb3c1-3834-4161-b3a1-4b3b49744cac}" FolderPath="02.DataConsistancy\">
      <Declaration><![CDATA[METHOD INTERNAL dataConsistancy01_NumOfOutersWrong
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0201				: FB_CASE_ValidateContent;
	rTrig0201					: R_TRIG;
	nCycles0201					: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0201, stProductInstruction:= stProductInstruction_test_0201);

//Change some data for test scenario below
stCACData_test_0201.NumberOfOuters := stCACData_test_0201.NumberOfOuters - 2;
	
TcUnit.TEST('dataConsistancy01_NumOfOutersWrong');


fbCaseTest0201(
	bExecute:= TRUE, 
	bIsDuplicateOuters:= FALSE, 
	bIsDuplicatePacks:= FALSE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0201, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
	stCaseRejectReasons:= stCaseRejectReasons_tests, 
	stCACData:= stCACData_test_0201, 
	bDone=> bDone, 
	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_test_0201, 
	nValidationIndex=> nValidationIndex
);
	
rTrig0201(CLK:= fbCaseTest0201.bDone);
nCycles0201 := nCycles0201 + 1;	

IF rTrig0201.Q THEN	
		
	AssertEquals_BOOL(Expected 	:= TRUE,
					  Actual 	:= bError,
					  Message 	:= 'Wrong number of outers not detected'
	);
	
	AssertEquals_STRING(Expected := 'XXVAL048XX',
						Actual := TO_STRING(fbCaseTest0201.sRejectCode),
						Message := 'Wrong value of nErrorID'
	);
	
	TEST_FINISHED();
	
ELSIF nCycles0201 > 50 THEN
	
	AssertTrue(Condition := TRUE,
			   Message 	 := 'Timeout dataConsistancy01_NumOfOutersWrong'
	);	 
	TEST_FINISHED();
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="dataConsistancy02_NumOfOutersExceedcMAX_Outers" Id="{44487056-36e5-48a9-a070-4cc0b8ddab89}" FolderPath="02.DataConsistancy\">
      <Declaration><![CDATA[METHOD INTERNAL dataConsistancy02_NumOfOutersExceedcMAX_Outers
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0202				: FB_CASE_ValidateContent;
	rTrig0202					: R_TRIG;
	nCycles0202					: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0202, stProductInstruction:= stProductInstruction_test_0202);

//Change some data for test scenario below
stCACData_test_0202.NumberOfOuters := - 1;
	
TcUnit.TEST('dataConsistancy02_NumOfOutersExceedcMAX_Outers');


fbCaseTest0202(
	bExecute:= TRUE, 
	bIsDuplicateOuters:= FALSE, 
	bIsDuplicatePacks:= FALSE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0202, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
	stCaseRejectReasons:= stCaseRejectReasons_tests, 
	stCACData:= stCACData_test_0202, 
	bDone=> bDone, 
	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_test_0202, 
	nValidationIndex=> nValidationIndex
);
	
rTrig0202(CLK:= fbCaseTest0202.bDone);
nCycles0202 := nCycles0202 + 1;	

IF rTrig0202.Q THEN	
		
	AssertEquals_UDINT(Expected := 11,
                   	   Actual 	:= fbCaseTest0202.nErrorID,
                   	   Message 	:= 'nErrorID value wrong');
	
	TEST_FINISHED();
	
ELSIF nCycles0202 > 50 THEN
	
	AssertTrue(Condition := TRUE,
			   Message 	 := 'Timeout dataConsistancy02_NumOfOutersExceedcMAX_Outers'
	);	 
	TEST_FINISHED();
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="dataConsistancy03_ValidationCodeNotFoundInInfeedQueue" Id="{336ee4a9-f0b9-4995-a14e-1e9387bc4d30}" FolderPath="02.DataConsistancy\">
      <Declaration><![CDATA[METHOD INTERNAL dataConsistancy03_ValidationCodeNotFoundInInfeedQueue
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0203				: FB_CASE_ValidateContent;
	rTrig0203					: R_TRIG;
	nCycles0203					: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0203, stProductInstruction:= stProductInstruction_test_0203);

//Change some data for test scenario below
stCACData_test_0203.NumberOfOuters := - 2;
	
TcUnit.TEST('dataConsistancy03_ValidationCodeNotFoundInInfeedQueue');


fbCaseTest0203(
	bExecute:= TRUE, 
	bIsDuplicateOuters:= FALSE, 
	bIsDuplicatePacks:= FALSE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0203, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
	stCaseRejectReasons:= stCaseRejectReasons_tests, 
	stCACData:= stCACData_test_0203, 
	bDone=> bDone, 
	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_test_0203, 
	nValidationIndex=> nValidationIndex
);
	
rTrig0203(CLK:= fbCaseTest0203.bDone);
nCycles0203 := nCycles0203 + 1;	

IF rTrig0203.Q THEN	
		
	AssertEquals_UDINT(Expected := 12,
                   	   Actual 	:= fbCaseTest0203.nErrorID,
                   	   Message 	:= 'nErrorID value wrong');
	
	TEST_FINISHED();
	
ELSIF nCycles0203 > 50 THEN
	
	AssertTrue(Condition := TRUE,
			   Message 	 := 'Timeout dataConsistancy03_ValidationCodeNotFoundInInfeedQueue'
	);	 
	TEST_FINISHED();
END_IF]]></ST>
      </Implementation>
    </Method>
