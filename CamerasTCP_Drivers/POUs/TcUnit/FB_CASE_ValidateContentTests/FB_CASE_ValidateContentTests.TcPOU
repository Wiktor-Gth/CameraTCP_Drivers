    <Method Name="oacMissing01nErrorID21" Id="{4db39697-f6a8-4ae3-8b98-60380f7630eb}" FolderPath="07.OACmissing\">
      <Declaration><![CDATA[METHOD INTERNAL oacMissing01nErrorID21
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	bCompare			: BOOL;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0701				: FB_CASE_ValidateContent;
	fTrig0701					: F_TRIG;	
	rTrig0701					: R_TRIG;
	nCycles0701					: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0701, stProductInstruction:= stProductInstruction_test_0701);

//Change some data for test scenario below
stCACData_test_0701.Outer[5].OuterRejectID := 207;
stProductInstruction_test_0701.nCaseAcceptanceLevelOuters := 50;
	
TcUnit.TEST('oacMissing01nErrorID21');


fbCaseTest0701(
	bExecute:= TRUE, 
	bIsDuplicateOuters:= FALSE, 
	bIsDuplicatePacks:= FALSE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0701, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
	stCaseRejectReasons:= stCaseRejectReasons_tests, 
	stCACData:= stCACData_test_0701, 
	bDone=> bDone, 
	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_tets, 
	nValidationIndex=> nValidationIndex
);
	
rTrig0701(CLK:= fbCaseTest0701.bDone);
nCycles0701 := nCycles0701 + 1;	



IF rTrig0701.Q THEN	
	
	bCompare := (stCACData_test_0701.CaseRejectID = stCaseRejectReasons_tests.stOACError.nRejectID);
	
	AssertEquals_BOOL(Expected 	:= TRUE,
					  Actual 	:= bError,
					  Message 	:= 'Pack duplicate did not call error'
	);
	
	AssertEquals_UDINT(Expected := 21,
                   	   Actual 	:= fbCaseTest0701.nErrorID,
                   	   Message 	:= 'Wrong nErrorID on OAC missing'
	);
	
	AssertEquals_BOOL(Expected 	:= TRUE,
					  Actual 	:= bCompare,
					  Message 	:= 'CaseRejectID wrong value'
	);	
	
	TEST_FINISHED();
	
ELSIF nCycles0701 > 50 THEN
	
	AssertTrue(Condition := TRUE,
			   Message 	 := 'Timeout oacMissing01nErrorID21'
	);	 
	TEST_FINISHED();
END_IF]]></ST>
      </Implementation>
    </Method>
