	TEST_FINISHED();
	
ELSIF nCycles0205 > 50 THEN
	
	AssertTrue(Condition := TRUE,
			   Message 	 := 'Timeout dataConsistancy05_NumberOfOutersToSmall'
	);	 
	TEST_FINISHED();
END_IF]]></ST>
      </Implementation>
    </Method>
