    <Method Name="duplicateHandler01_OuterDuplicatebErrorTrue" Id="{78319de4-45f3-4e2b-a121-b631d955473f}" FolderPath="06. DuplicatesHandler\">
      <Declaration><![CDATA[METHOD INTERNAL duplicateHandler01_OuterDuplicatebErrorTrue
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0601				: FB_CASE_ValidateContent;
	fTrig						: F_TRIG;	
	rTrig						: R_TRIG;
	nCycles						: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0601, stProductInstruction:= stProductInstruction_test_0601);

//Change some data for test scenario below
//stCACData_test_0303.NumberOfOuters := 51;

	
TcUnit.TEST('duplicateHandler01_OuterDuplicatebErrorTrue');


fbCaseTest0601(
	bExecute:= TRUE, 
	bIsDuplicateOuters:= TRUE, 
	bIsDuplicatePacks:= FALSE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0601, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
	stCaseRejectReasons:= stCaseRejectReasons_tests, 
	stCACData:= stCACData_test_0601, 
	bDone=> bDone, 
	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_tets, 
	nValidationIndex=> nValidationIndex
);
	
rTrig(CLK:= fbCaseTest0601.bDone);
nCycles := nCycles + 1;	

IF rTrig.Q THEN	
		
	AssertEquals_BOOL(Expected 	:= TRUE,
					  Actual 	:= bError,
					  Message 	:= 'Outer duplicate did not call error'
	);
	
	AssertEquals_UDINT(Expected := 1,
                   	   Actual 	:= fbCaseTest0601.nErrorID,
                   	   Message 	:= 'Wrong nErrorID on outer duplicate'
	);
	
	TEST_FINISHED();
	
ELSIF nCycles > 50 THEN
	
	AssertTrue(Condition := TRUE,
			   Message 	 := 'Timeout duplicateHandler01_OuterDuplicatebErrorTrue'
	);	 
	TEST_FINISHED();
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="duplicateHandler02_PackDuplicatebErrorTrue" Id="{464dcacd-701b-41b2-9a7f-ba9a23d3d004}" FolderPath="06. DuplicatesHandler\">
      <Declaration><![CDATA[METHOD INTERNAL duplicateHandler02_PackDuplicatebErrorTrue
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0602				: FB_CASE_ValidateContent;
	fTrig						: F_TRIG;	
	rTrig						: R_TRIG;
	nCycles						: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0602, stProductInstruction:= stProductInstruction_test_0602);

//Change some data for test scenario below

	
TcUnit.TEST('duplicateHandler02_PackDuplicatebErrorTrue');


fbCaseTest0602(
	bExecute:= TRUE, 
	bIsDuplicateOuters:= FALSE, 
	bIsDuplicatePacks:= TRUE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0602, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
	stCaseRejectReasons:= stCaseRejectReasons_tests, 
	stCACData:= stCACData_test_0602, 
	bDone=> bDone, 
	bBusy=> bBusy, 
	bError=> bError, 
	nErrorID=> nErrorID, 
	sRejectCode=> sRejectCode_tets, 
	nValidationIndex=> nValidationIndex
);
	
rTrig(CLK:= fbCaseTest0602.bDone);
nCycles := nCycles + 1;	

IF rTrig.Q THEN	
		
	AssertEquals_BOOL(Expected 	:= TRUE,
					  Actual 	:= bError,
					  Message 	:= 'Pack duplicate did not call error'
	);
	
	AssertEquals_UDINT(Expected := 1,
                   	   Actual 	:= fbCaseTest0602.nErrorID,
                   	   Message 	:= 'Wrong nErrorID on pack duplicate'
	);
	
	TEST_FINISHED();
	
ELSIF nCycles > 50 THEN
	
	AssertTrue(Condition := TRUE,
			   Message 	 := 'Timeout duplicateHandler02_PackDuplicatebErrorTrue'
	);	 
	TEST_FINISHED();
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="main01_bExecuteFalseNoAction" Id="{329929f8-6ef8-4f4c-8fb5-705facb92eaf}" FolderPath="01.Main\">
      <Declaration><![CDATA[METHOD INTERNAL main01_bExecuteFalseNoAction
VAR
	//fbCaseTest			: FB_CASE_ValidateContent;
	bDone				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorID 			: UDINT;
	nValidationIndex	: INT;
	
	eLastState			: E_CAC_State;
			
END_VAR

VAR_INST
	fbCaseTest0101				: FB_CASE_ValidateContent;
	fTrig						: F_TRIG;	
	rTrig						: R_TRIG;
	nCycles						: INT;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//Data initialization
TestInit(stCACData:= stCACData_test_0101, stProductInstruction:= stProductInstruction_test_0101);

//Change some data for test scenario below

	
TcUnit.TEST('main01_bExecuteFalseNoAction');


fbCaseTest0101(
	bExecute:= FALSE, 
	bIsDuplicateOuters:= FALSE, 
	bIsDuplicatePacks:= FALSE, 
	stCTDateTime:= stCTDateTime_tests, 
	stOuterDataNotFound:= stRejectReasonsForOuter_tests.stOuterDataNotFound, 
	stProductInstruction:= stProductInstruction_test_0101, 
	nSecquentionalCounter:= nSecquentionalCounter_tests, 
	stCodeInfo_Outer:= stCodeInfo_Outer_tests, 
